#!/usr/bin/env python3
"""Force-clear any celebration overlay still on the kiosk page. Useful when
a long-running celebration (like walkup) didn't clean up on its own."""
import json, urllib.request, websocket

JS = r"""
(() => {
  const SELECTORS = [
    '.walkup-bg', '.walkup-light', '.walkup-strobe', '.walkup-name',
    '.walkup-spotlight', '.walkup-subtitle', '.walkup-track',
    '.easy-overlay', '.easy-button', '.easy-text', '.easy-flash',
    '.easy-mini-flash', '.easy-boom', '.easy-ripple', '.easy-sparkle',
    '.money-flash', '.money-text', '.money-counter', '.money-cash-stack',
    '.money-slot', '.money-jackpot', '.money-coin', '.money-bill',
  ].join(',');
  const removed = document.querySelectorAll(SELECTORS).length;
  document.querySelectorAll(SELECTORS).forEach(e => e.remove());
  document.querySelectorAll('#__walkup_styles, #__money_styles, #__easy_styles').forEach(e => e.remove());
  // Stop any orphaned <audio> elements playing in JS land (they aren't in the DOM)
  return JSON.stringify({removed});
})()
"""

def main():
    tabs = json.loads(urllib.request.urlopen('http://127.0.0.1:9222/json').read())
    page = next((t for t in tabs if t.get('type') == 'page'), None)
    if not page:
        print('no page'); return 1
    ws = websocket.create_connection(page['webSocketDebuggerUrl'], timeout=5)
    ws.send(json.dumps({'id': 1, 'method': 'Runtime.evaluate',
        'params': {'expression': JS, 'returnByValue': True}}))
    resp = json.loads(ws.recv())
    val = resp.get('result', {}).get('result', {}).get('value', '{}')
    info = json.loads(val) if isinstance(val, str) else val
    print(f'🧹 cleared {info.get("removed", 0)} celebration elements')
    return 0

if __name__ == '__main__':
    raise SystemExit(main())
