#!/usr/bin/env python3
"""'That was easy' celebration — giant red button + audio line.
Audio is the user's pre-generated MP3 at /opt/easy.mp3, embedded as a data URL
(more reliable than Chromium's speechSynthesis on Linux)."""
import base64, json, os, urllib.request, websocket

EASY_MP3 = '/opt/easy.mp3'

def main():
    if not os.path.exists(EASY_MP3):
        print(f'missing {EASY_MP3}'); return 1
    muted = os.path.exists('/etc/kiosk-mute')
    with open(EASY_MP3, 'rb') as f:
        audio_data_url = 'data:audio/mpeg;base64,' + base64.b64encode(f.read()).decode()

    js = r"""
    (async () => {
      console.log('[easy] starting');
      // Defensive: clear any leftover overlay from any prior celebration
      document.querySelectorAll(
        '.walkup-bg, .walkup-light, .walkup-strobe, .walkup-name, .walkup-spotlight, .walkup-subtitle, .walkup-track, .easy-overlay, .easy-button, .easy-text, .easy-flash, .easy-mini-flash, .easy-boom, .easy-ripple, .easy-sparkle, .money-flash, .money-text, .money-counter, .money-cash-stack'
      ).forEach(e => e.remove());
      const styleId = '__easy_styles';
      if (!document.getElementById(styleId)) {
        const css = document.createElement('style'); css.id = styleId;
        css.textContent = `
          @keyframes easy-button-in {
            0%   { transform: translate(-50%,-50%) scale(0) rotate(-45deg); }
            60%  { transform: translate(-50%,-50%) scale(1.25) rotate(8deg); }
            100% { transform: translate(-50%,-50%) scale(1.1) rotate(0); }
          }
          @keyframes easy-button-press {
            0%,100% { transform: translate(-50%,-50%) scale(1.1); }
            50%     { transform: translate(-50%,-50%) scale(0.85); }
          }
          @keyframes easy-pulse {
            0%,100% { box-shadow: 0 20px 0 #500, 0 25px 60px rgba(0,0,0,0.7), 0 0 0 0 rgba(255,80,80,0.6), inset 0 -8px 16px rgba(0,0,0,0.4); }
            50%     { box-shadow: 0 20px 0 #500, 0 25px 60px rgba(0,0,0,0.7), 0 0 0 30vmin rgba(255,80,80,0), inset 0 -8px 16px rgba(0,0,0,0.4); }
          }
          @keyframes easy-ripple {
            0%   { transform: translate(-50%,-50%) scale(0.6); opacity: 0.7; }
            100% { transform: translate(-50%,-50%) scale(4); opacity: 0; }
          }
          @keyframes easy-text-in {
            0%   { transform: translate(-50%,0) scale(0); opacity: 0; }
            50%  { transform: translate(-50%,0) scale(1.3); opacity: 1; }
            100% { transform: translate(-50%,0) scale(1); opacity: 1; }
          }
          @keyframes easy-sparkle {
            0%,100% { transform: scale(0) rotate(0); opacity: 0; }
            50%     { transform: scale(1.3) rotate(180deg); opacity: 1; }
          }
          .easy-overlay { position: fixed; inset: 0; pointer-events: none; z-index: 2147483640;
            background: radial-gradient(circle at center, rgba(0,0,0,0.4), rgba(0,0,0,0.7)); }
          .easy-button {
            position: fixed; left: 50%; top: 50%;
            width: 50vmin; height: 50vmin; border-radius: 50%;
            background: radial-gradient(circle at 35% 30%, #ff7777, #cc0000 55%, #660000);
            animation: easy-button-in 0.7s cubic-bezier(.4,1.6,.4,1) forwards, easy-pulse 2.3s ease-out 0.85s infinite;
            display: flex; align-items: center; justify-content: center;
            font-family: -apple-system, system-ui, sans-serif;
            font-size: 11vmin; font-weight: 900; color: white;
            letter-spacing: 0.05em;
            text-shadow: 0 4px 8px rgba(0,0,0,0.7);
            border: 4px solid rgba(255,255,255,0.3);
            z-index: 2147483645;
          }
          .easy-button.pressed { animation: easy-button-press 0.43s ease-out forwards; }
          .easy-ripple {
            position: fixed; left: 50%; top: 50%;
            width: 50vmin; height: 50vmin; border-radius: 50%;
            border: 6px solid #ff5555; pointer-events: none;
            animation: easy-ripple 2s ease-out forwards;
            z-index: 2147483643;
          }
          .easy-text {
            position: fixed; left: 50%; top: 80vh;
            font-family: -apple-system, system-ui, sans-serif;
            font-weight: 900; color: white;
            letter-spacing: 0.03em;
            text-align: center;
            text-shadow: 0 6px 16px rgba(0,0,0,0.9), 0 0 40px rgba(255,255,255,0.4), 0 0 60px rgba(255,80,80,0.5);
            white-space: nowrap; pointer-events: none;
            animation: easy-text-in 1s cubic-bezier(.4,1.5,.4,1) forwards;
            z-index: 2147483645;
            /* font-size set in JS via measure-and-shrink (vw is unreliable on this rotated kiosk) */
          }
          .easy-sparkle {
            position: fixed; pointer-events: none; font-size: 60px;
            animation: easy-sparkle 1.43s ease-in-out forwards;
            z-index: 2147483644;
          }
          @keyframes easy-flash {
            0%   { opacity: 0; }
            8%   { opacity: 1; }
            100% { opacity: 0; }
          }
          .easy-flash {
            position: fixed; inset: 0; pointer-events: none;
            background: white; z-index: 2147483647;
            animation: easy-flash 0.55s ease-out forwards;
          }
          .easy-mini-flash {
            position: fixed; width: 18vmin; height: 18vmin; border-radius: 50%;
            background: radial-gradient(circle, white 0%, rgba(255,255,200,0.7) 35%, transparent 70%);
            pointer-events: none; z-index: 2147483646;
            animation: easy-flash 0.6s ease-out forwards;
          }
          @keyframes easy-boom {
            0%   { transform: translate(-50%,-50%) scale(0) rotate(-40deg); opacity: 0; }
            22%  { transform: translate(-50%,-50%) scale(1.35) rotate(18deg); opacity: 1; }
            38%  { transform: translate(-50%,-50%) scale(0.92) rotate(-6deg); opacity: 1; }
            55%  { transform: translate(-50%,-50%) scale(1.12) rotate(8deg); opacity: 1; }
            80%  { transform: translate(-50%,-50%) scale(1.05) rotate(-2deg); opacity: 1; }
            100% { transform: translate(-50%,-50%) scale(1.05) rotate(0); opacity: 0; }
          }
          .easy-boom {
            position: fixed; left: 75%; top: 30%;
            width: 30vmin; height: 30vmin;
            background: radial-gradient(circle, #fff59d 0%, #ffeb3b 25%, #ff9800 70%, #d84315 100%);
            clip-path: polygon(
              50% 0%, 58% 22%, 78% 8%, 72% 30%, 96% 26%, 78% 44%, 100% 52%,
              78% 60%, 96% 78%, 72% 72%, 78% 96%, 58% 80%, 50% 100%, 42% 80%,
              22% 96%, 28% 72%, 4% 78%, 22% 60%, 0% 52%, 22% 44%, 4% 26%, 28% 30%, 22% 8%, 42% 22%
            );
            display: flex; align-items: center; justify-content: center;
            font-family: -apple-system, system-ui, sans-serif;
            font-weight: 900; color: #b71c1c;
            text-shadow: 2px 2px 0 rgba(255,255,255,0.4);
            z-index: 2147483646; pointer-events: none;
            animation: easy-boom 1.1s cubic-bezier(.4,1.4,.4,1) forwards;
          }
        `;
        document.head.appendChild(css);
      }

      const overlay = document.createElement('div'); overlay.className = 'easy-overlay';
      const btn = document.createElement('div'); btn.className = 'easy-button'; btn.textContent = 'EASY';
      document.body.append(overlay, btn);
      console.log('[easy] button placed');

      // Start audio immediately so it lines up with the press
      let audio = null;
      if (!__MUTED__) {
        audio = new Audio(__AUDIO__);
        audio.volume = 1.0;
        audio.play().catch(e => console.error('[easy] audio play failed:', e));
        window.__rayluTeardown = window.__rayluTeardown || [];
        window.__rayluTeardown.push(() => { try { audio.pause(); audio.src = ''; } catch (e) {} });
      }

      setTimeout(() => {
        btn.classList.add('pressed');
        console.log('[easy] pressed');

        // Camera flash + 4 paparazzi mini-flashes
        const flash = document.createElement('div'); flash.className = 'easy-flash';
        document.body.appendChild(flash);
        setTimeout(() => flash.remove(), 600);
        for (let i = 0; i < 4; i++) {
          const mf = document.createElement('div'); mf.className = 'easy-mini-flash';
          mf.style.left = (10 + Math.random() * 80) + 'vw';
          mf.style.top = (10 + Math.random() * 70) + 'vh';
          mf.style.animationDelay = (i * 0.08) + 's';
          document.body.appendChild(mf);
          setTimeout(() => mf.remove(), 800 + i * 80);
        }

        // BOOM starburst sticker (upper-right of button, doesn't cover it)
        setTimeout(() => {
          const boom = document.createElement('div'); boom.className = 'easy-boom';
          boom.textContent = 'EZ!';
          // Size text relative to sticker — measure once
          boom.style.fontSize = Math.floor(innerWidth * 0.06) + 'px';
          document.body.appendChild(boom);
          setTimeout(() => boom.remove(), 1200);
        }, 350);

        // ripples
        for (let i = 0; i < 4; i++) {
          const r = document.createElement('div'); r.className = 'easy-ripple';
          r.style.animationDelay = (i * 0.29) + 's';
          document.body.appendChild(r);
          setTimeout(() => r.remove(), 2430 + i * 286);
        }
        // sparkles around the button
        const sparkles = ['✨','⭐','💫','🌟'];
        for (let i = 0; i < 24; i++) {
          const s = document.createElement('div'); s.className = 'easy-sparkle';
          s.textContent = sparkles[Math.floor(Math.random()*sparkles.length)];
          const angle = (i / 24) * Math.PI * 2;
          const r = 30 + Math.random() * 15;
          s.style.left = `calc(50% + ${Math.cos(angle) * r}vmin)`;
          s.style.top = `calc(50% + ${Math.sin(angle) * r}vmin)`;
          s.style.animationDelay = (i * 0.057) + 's';
          s.style.fontSize = (40 + Math.random() * 40) + 'px';
          document.body.appendChild(s);
          setTimeout(() => s.remove(), 2143 + i * 71);
        }

        // Big "THAT WAS EASY" text below button — measure-and-shrink to fit
        setTimeout(() => {
          const t = document.createElement('div'); t.className = 'easy-text';
          t.textContent = 'THAT WAS EASY';
          document.body.appendChild(t);
          const maxW = Math.floor(innerWidth * 0.90);
          let fs = Math.floor(innerWidth * 0.10);
          t.style.fontSize = fs + 'px';
          while (t.scrollWidth > maxW && fs > 24) {
            fs = Math.floor(fs * 0.93);
            t.style.fontSize = fs + 'px';
          }
          console.log('[easy] text sized to', fs, 'px, width', t.scrollWidth, 'of max', maxW);
          setTimeout(() => t.remove(), 5715);
        }, 358);
      }, 715);

      setTimeout(() => { overlay.remove(); btn.remove(); if (audio) audio.pause(); console.log('[easy] cleanup'); }, 9286);
      return 'easy';
    })()
    """
    js = js.replace('__AUDIO__', json.dumps(audio_data_url)).replace('__MUTED__', 'true' if muted else 'false')

    tabs = json.loads(urllib.request.urlopen('http://127.0.0.1:9222/json').read())
    page = next((t for t in tabs if t.get('type') == 'page'), None)
    if not page: print('no page'); return 1
    ws = websocket.create_connection(page['webSocketDebuggerUrl'], timeout=5)
    ws.send(json.dumps({'id': 1, 'method': 'Runtime.evaluate',
        'params': {'expression': js, 'awaitPromise': True, 'returnByValue': True}}))
    resp = json.loads(ws.recv())
    if resp.get('result', {}).get('result', {}).get('value') == 'easy':
        print('🟥 that was easy'); return 0
    print('unexpected:', resp); return 1

if __name__ == '__main__':
    raise SystemExit(main())
